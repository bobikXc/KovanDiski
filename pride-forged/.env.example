PROJECT_NAME=pride-forged

POSTGRES_DB=pride_forged
POSTGRES_USER=pride
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DB
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

NEXT_PUBLIC_API_URL=/api
INTERNAL_API_URL=http://backend:8000/api

# Create a bot and get its token from @BotFather in Telegram.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Send the bot a message, then find chat.id in https://api.telegram.org/bot<TOKEN>/getUpdates.
TELEGRAM_CHAT_ID=your_telegram_chat_id
